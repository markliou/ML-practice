# providing the public key for loggin (optional)
RUN mkdir /root/.ssh ;\
    touch /root/.ssh/authorized_keys ;\
    chmod 644 /root/.ssh ;\
    chmod 644 /root/.ssh/authorized_keys ;\
    echo ssh-rsa  markliou@markliou-ZBPDuo >> /root/.ssh/authorized_keys

# RUN mkdir /workspace
WORKDIR /workspace

# IPython
EXPOSE 8888
# TensorBoard
EXPOSE 6006
# ssh
EXPOSE 22

CMD ["/etc/init.d/ssh", "start", "-D"]
